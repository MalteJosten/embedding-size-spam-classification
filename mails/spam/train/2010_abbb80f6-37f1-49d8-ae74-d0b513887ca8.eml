\u041d\u0430\u0438\u0434\u043e\u0441\u0442\u0443\u043f\u043d\u0435\u0439\u0448\u0430\u044f \u0440\u0435\u043a\u043b\u0430\u043c\u0430 \u043f\u043b\u0430\u043d\u0435\u0442\u044b \u0417\u0435\u043c\u043b\u044f+ 7 ( 495) 2 2-015-5 8\u0411\u0438\u0437\u043d\u0435\u0441 \u041c\u043e\u0441\u043a\u0432\u044b - 1 \u0437\u0430 \u0442\u0440\u0438, 2 \u0437\u0430 \u0447\u0435\u0442\u044b\u0440\u0435, 3 \u0437\u0430 \u043f\u044f\u0442\u044c \u0442\u044b\u0441\u044f\u0447 \u0440\u0443\u0431\u043b\u0435\u0439\u041e\u0431\u0449\u0430\u044f \u041c\u043e\u0441\u043a\u0432\u0430 - 1 \u0437\u0430 \u0447\u0435\u0442\u044b\u0440\u0435, 2 \u0437\u0430 \u043f\u044f\u0442\u044c \u0441 \u043f\u043e\u043b\u043e\u0432\u0438\u043d\u043e\u0439, 3 \u0437\u0430 \u0441\u0435\u043c\u044c \u0442\u044b\u0441\u044f\u0447 \u0440\u0443\u0431\u043b\u0435\u0439\u0420\u043e\u0441\u0441\u0438\u044f \u043c\u0438\u043a\u0441 - 1 \u0437\u0430 \u0441\u0435\u043c\u044c , 2 \u0437\u0430 \u0434\u0435\u0441\u044f\u0442\u044c, 3 \u0437\u0430 \u0434\u0432\u0435\u043d\u0430\u0434\u0446\u0430\u0442\u044c \u0442\u044b\u0441\u044f\u0447 \u0440\u0443\u0431\u043b\u0435\u0439\u0423\u043b\u044b\u0431\u043e\u0447\u043a\u0430 \u0438 \u043f\u0430\u0440\u0430 \u0441\u043b\u043e\u0432,\u0418 \u043a\u0442\u043e \u0432\u043b\u044e\u0431\u043b\u0435\u043d - \u043d\u0430 \u0432\u0441\u0435 \u0433\u043e\u0442\u043e\u0432.\u0410.\u0421. \u0413\u0440\u0438\u0431\u043e\u0435\u0434\u043e\u0432. \u0413\u043e\u0440\u0435 \u043e\u0442 \u0443\u043c\u0430\u041a\u043e\u0433\u0434\u0430 \u043d\u0430\u043c \u043a\u0430\u0436\u0435\u0442\u0441\u044f, \u0447\u0442\u043e \u043c\u044b \u0437\u043d\u0430\u0435\u043c \u0434\u0440\u0443\u0433\u043e\u0433\u043e, - \u044d\u0442\u043e \u0432\u0441\u044f\u043a\u0438\u0439 \u0440\u0430\u0437 \u043e\u0437\u043d\u0430\u0447\u0430\u0435\u0442 \u043a\u043e\u043d\u0435\u0446 \u043b\u044e\u0431\u0432\u0438. \u041c\u0430\u043a\u0441 \u0424\u0440\u0438\u0448\u0421\u0442\u0440\u0435\u043c\u043b\u0435\u043d\u0438\u0435 \u043d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0445 \u0441\u0442\u0430\u0440\u0438\u043a\u043e\u0432 \u043b\u044e\u0431\u0438\u0442\u044c \u043c\u043e\u043b\u043e\u0434\u044b\u0445 \u0436\u0435\u043d\u0449\u0438\u043d \u043d\u0435\u0440\u0430\u0437\u0443\u043c\u043d\u043e \u0435\u0449\u0435 \u0438 \u043f\u043e\u0442\u043e\u043c\u0443, \u0447\u0442\u043e \u043e\u043d\u0438 \u0442\u0440\u0435\u0431\u0443\u044e\u0442 \u043a \u0441\u0435\u0431\u0435 \u043e\u0442\u0432\u0435\u0442\u043d\u0443\u044e \u043b\u044e\u0431\u043e\u0432\u044c \u0438 \u043f\u0438\u0442\u0430\u044e\u0442\u0441\u044f \u0438\u043b\u043b\u044e\u0437\u0438\u0435\u0439, \u0447\u0442\u043e \u043e\u043d\u0438 \u0435\u0449\u0435 \u0432\u043f\u0440\u0430\u0432\u0435 \u043d\u0430 \u044d\u0442\u043e \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u0442\u044c. \u0412\u043f\u0440\u043e\u0447\u0435\u043c, \u0432\u0438\u043d\u0430 \u0437\u0434\u0435\u0441\u044c \u043d\u0435 \u0442\u043e\u043b\u044c\u043a\u043e \u0441\u0430\u043c\u0438\u0445 \u0441\u0442\u0430\u0440\u0438\u043a\u043e\u0432, \u0430 \u0438 \u0442\u0435\u0445 \u043c\u043e\u043b\u043e\u0434\u044b\u0445 \u0436\u0435\u043d\u0449\u0438\u043d, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u044e\u0442 \u0432 \u043d\u0438\u0445 \u044d\u0442\u043e \u043d\u0435\u0440\u0430\u0437\u0443\u043c\u0438\u0435. \u0416. \u041b\u0430\u0431\u0440\u044e\u0439\u0435\u0440. \u041b\u044e\u0431\u043e\u0432\u044c \u0432\u0441\u0435\u0441\u0438\u043b\u044c\u043d\u0430: \u043d\u0435\u0442 \u043d\u0430 \u0437\u0435\u043c\u043b\u0435 \u043d\u0438 \u0433\u043e\u0440\u044f - \u0432\u044b\u0448\u0435 \u043a\u0430\u0440\u044b \u0435\u0435, \u043d\u0438 \u0441\u0447\u0430\u0441\u0442\u044c\u044f - \u0432\u044b\u0448\u0435 \u043d\u0430\u0441\u043b\u0430\u0436\u0434\u0435\u043d\u0438\u044f \u0441\u043b\u0443\u0436\u0438\u0442\u044c \u0435\u0439. \u0423. \u0428\u0435\u043a\u0441\u043f\u0438\u0440. \u041a\u0442\u043e \u043d\u0435 \u043b\u044e\u0431\u0438\u0442, \u0442\u043e\u0442 \u043d\u0435 \u043f\u043e\u0437\u043d\u0430\u043b \u0411\u043e\u0433\u0430, \u043f\u043e\u0442\u043e\u043c\u0443 \u0447\u0442\u043e \u0411\u043e\u0433 \u0435\u0441\u0442\u044c \u043b\u044e\u0431\u043e\u0432\u044c. 1-\u0435 \u0418\u043e\u0430\u043d\u043d\u0430, 4:7-8\u041b\u044e\u0431\u043e\u0432\u044c - \u0432\u0440\u0430\u0433 \u0438\u0437\u043b\u0438\u0448\u0435\u0441\u0442\u0432. \u0412 \u043d\u0435\u0439, \u043a\u0430\u043a \u0432 \u0435\u0434\u0435, \u0441\u043b\u0435\u0434\u0443\u0435\u0442 \u043e\u0442\u0434\u0430\u0432\u0430\u0442\u044c \u043f\u0440\u0435\u0434\u043f\u043e\u0447\u0442\u0435\u043d\u0438\u0435 \u043d\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0443, \u0430 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0443. \u0418\u0441\u0442\u0438\u043d\u043d\u043e\u0435 \u043d\u0430\u0441\u043b\u0430\u0436\u0434\u0435\u043d\u0438\u0435 \u043a\u043e\u043d\u0447\u0430\u0435\u0442\u0441\u044f, \u043a\u043e\u0433\u0434\u0430 \u043d\u0430\u0447\u0438\u043d\u0430\u0435\u0442\u0441\u044f \u0440\u0430\u0441\u043f\u0443\u0442\u0441\u0442\u0432\u043e, \u0438\u0431\u043e, \u043f\u043e\u0433\u0440\u044f\u0437\u043d\u0443\u0432 \u0432 \u043d\u0435\u043c, \u043f\u0440\u0438\u0445\u043e\u0434\u0438\u0448\u044c \u043a \u043e\u0442\u0432\u0440\u0430\u0449\u0435\u043d\u0438\u044e. \u0420\u0430\u0437\u0432\u0435 \u0442\u043e\u0442, \u043a\u0442\u043e \u0436\u0440\u0435\u0442, \u043a\u0430\u043a \u0441\u0432\u0438\u043d\u044c\u044f, \u0438 \u043d\u0430\u043b\u0438\u0432\u0430\u0435\u0442\u0441\u044f \u0432\u0438\u043d\u043e\u043c, \u043a\u0430\u043a \u0431\u0435\u0437\u0434\u043e\u043d\u043d\u0430\u044f \u0431\u043e\u0447\u043a\u0430, \u0441\u043f\u043e\u0441\u043e\u0431\u0435\u043d \u0443\u043f\u0438\u0432\u0430\u0442\u044c\u0441\u044f \u043f\u0440\u0435\u043b\u0435\u0441\u0442\u044c\u044e \u0438\u0437\u044b\u0441\u043a\u0430\u043d\u043d\u043e\u0433\u043e \u043f\u043e\u0446\u0435\u043b\u0443\u044f? \u0410 \u0438 \u0421. \u0413\u043e\u043b\u043e\u043d. 