27\u0626\u0647\u06cc \u062e\u062f\u0645\u0627\u062a \u0628\u0648\u0631\u0633\u064a \u0648 \u0627\u0642\u062a\u0635\u0627\u062f\u064a \u062f\u0631\u0627\u0648\u0627\u064a\u0644 \u062a\u064a\u0631 \u0645\u0627\u0647 \u0631\u0648\u0646\u0645\u0627\u064a\u064a \u0634\u062f\u060c \u0648 \u0645\u0648\u0631\u062f \u0627\u0633\u062a\u0642\u0628\u0627\u0644\u06a9\u0627\u0631\u0628\u0631\u0627\u0646 \u0648 \u0641\u0639\u0627\u0644\u0627\u0646 \u0628\u0627\u0632\u0627\u0631 \u0633\u0631\u0645\u0627\u064a\u0647 \u0642\u0631\u0627\u0631 \u06af\u0631\u0641\u062a.\u062e\u062f\u0645\u0627\u062a \u0633\u0627\u064a\u062a \u0634\u0627\u0645\u0644 \u0627\u0631\u0627\u0626\u0647&zwnj;\u064a \u0627\u0646\u0648\u0627\u0639 \u0627\u062e\u0628\u0627\u0631\u0628\u0648\u0631\u0633\u064a\u060c \u06af\u0632\u0627\u0631\u0634\u0627\u062a \u0645\u062c\u0627\u0645\u0639 \u0648 \u0634\u0631\u06a9\u062a&zwnj;\u0647\u0627\u060c\u0627\u0631\u0627\u0626\u0647&zwnj;\u064a \u067e\u064a\u0634\u0646\u0647\u0627\u062f\u0647\u0627\u064a \u062e\u0631\u064a\u062f \u0648 \u0641\u0631\u0648\u0634 \u0633\u0647\u0627\u0645\u060c\u06af\u0632\u0627\u0631\u0634 \u0628\u0627\u0632\u0627\u0631\u060c \u067e\u064a\u0634&zwnj;\u0628\u064a\u0646\u064a \u0628\u0627\u0632\u0627\u0631 \u0648 \u062e\u062f\u0645\u0627\u062a\u062f\u064a\u06af\u0631 \u0628\u0648\u0631\u0633\u064a \u0628\u0647 \u0637\u0648\u0631 \u062e\u0627\u0635 \u0645\u064a&zwnj;\u0628\u0627\u0634\u062f. \u062e\u0628\u0631\u0647\u0627\u064a\u0627\u0642\u062a\u0635\u0627\u062f\u064a \u0648 \u06af\u0648\u0646\u0627\u06af\u0648\u0646 \u0646\u064a\u0632 \u062f\u0631 \u062c\u0647\u062a \u0627\u0637\u0644\u0627\u0639\u0627\u062a \u0648\u0645\u0637\u0627\u0644\u0639\u0647&zwnj;\u064a \u06a9\u0627\u0631\u0628\u0631\u0627\u0646 \u0645\u0648\u0631\u062f \u067e\u0648\u0634\u0634 \u0642\u0631\u0627\u0631 \u062f\u0627\u062f\u0647\u0645\u064a \u0634\u0648\u062f. \u0633\u0627\u064a\u062a \u0628\u0648\u0631\u0633 2080 \u0628\u0627 \u0645\u062c\u0645\u0648\u0639\u0647&zwnj;\u06